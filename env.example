# ============================================
# Конфигурация системы управления договорами
# ============================================

# ============================================
# База данных (MySQL)
# ============================================
# Для локального развертывания используйте значения по умолчанию
# Для production измените на безопасные значения

MYSQL_ROOT_PASSWORD=rootpassword123
MYSQL_DATABASE=contract_management
MYSQL_USER=contract_user
MYSQL_PASSWORD=contractpass123
DB_PORT=3306

# Строка подключения к БД (автоматически генерируется из переменных выше)
# DATABASE_URL=mysql://contract_user:contractpass123@db:3306/contract_management

# ============================================
# Аутентификация и безопасность
# ============================================
# ВАЖНО: Измените на длинный случайный ключ в production
# Минимум 32 символа
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ============================================
# OAuth интеграция (опционально)
# ============================================
VITE_APP_ID=local-app-id
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000

# ============================================
# Владелец системы
# ============================================
OWNER_OPEN_ID=owner-id
OWNER_NAME=System Owner

# ============================================
# API интеграции (опционально)
# ============================================
BUILT_IN_FORGE_API_URL=http://localhost:3000
BUILT_IN_FORGE_API_KEY=local-api-key
VITE_FRONTEND_FORGE_API_KEY=local-frontend-key
VITE_FRONTEND_FORGE_API_URL=http://localhost:3000

# ============================================
# S3 хранилище для файлов
# ============================================
# Для локального развертывания используется MinIO
# Для production используйте AWS S3 или другой S3-совместимый сервис

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET_NAME=contract-files

# ============================================
# Порты приложения
# ============================================
APP_PORT=3000

# ============================================
# Окружение
# ============================================
NODE_ENV=production
